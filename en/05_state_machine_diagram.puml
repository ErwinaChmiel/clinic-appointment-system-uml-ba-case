@startuml
skinparam monochrome true
skinparam shadowing false

title Appointment - state machine

[*] --> "New booking"

"New booking" --> "Payment pending" : [prepayment required]
"New booking" --> "Confirmed" : [no prepayment]

"Payment pending" --> "Confirmed" : [payment accepted]
"Payment pending" --> "Cancelled" : [payment rejected / timeout]

"Confirmed" --> "Cancelled" : [cancelled by patient or reception]
"Confirmed" --> "In progress" : [appointment started]
"Confirmed" --> "No-show" : [patient did not arrive]

"In progress" --> "Completed" : [appointment completed]

"Cancelled" --> [*]
"Completed" --> [*]
"No-show" --> [*]
@enduml
